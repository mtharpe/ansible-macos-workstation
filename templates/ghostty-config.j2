# {{ ansible_managed }}
# Ghostty Terminal Configuration

font-family = "FiraCode Nerd Font"
font-size = 17
adjust-cell-height = 6%

maximize
title = "Terminal"

desktop-notifications = false

# Auto-attach (or create) tmux session 'main' on launch
command = /opt/homebrew/bin/fish -l -c "tmux attach -t main || tmux new -s main"
